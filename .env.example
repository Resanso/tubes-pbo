# ─── Backend — Neon DB ────────────────────────────────────────────────────────
# Get these from your Neon project dashboard → Connection Details
DATABASE_URL=jdbc:postgresql://<host>/<dbname>?sslmode=require
DATABASE_USERNAME=<neon-username>
DATABASE_PASSWORD=<neon-password>

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use a long random string; generate with: openssl rand -hex 64
JWT_SECRET=change-me-to-a-long-random-secret
